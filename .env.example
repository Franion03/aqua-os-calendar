# ── AquaOS — Unified Environment Configuration ────────────────────
# Copy to .env:   cp .env.example .env
# Edit secrets:   vim .env

# ── LLM Providers (at least one required for CrewAI) ──────────────
OPENROUTER_API_KEY=sk-or-v1-...
GEMINI_API_KEY=AIza...

# ── Auth (shared across all services) ─────────────────────────────
JWT_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS
JWT_ISSUER=AquaOsCalendar
JWT_AUDIENCE=AquaOsCalendar

# Admin credentials (used by Go backend + Calendar service)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME

# ── Service Ports ─────────────────────────────────────────────────
WEB_PORT=3000
BACKEND_PORT=8080
CALENDAR_PORT=8082
CREW_PORT=8001

# ── AWS / DynamoDB ────────────────────────────────────────────────
AWS_REGION=eu-west-1
# For local dev: uncomment to use DynamoDB Local instead of AWS
# DYNAMODB_URL=http://dynamodb-local:8000
DYNAMODB_LOCAL_PORT=8000

# ── Google Calendar Sync (optional) ───────────────────────────────
# 1. Create a service account: https://console.cloud.google.com/iam-admin/serviceaccounts
# 2. Enable Calendar API: https://console.cloud.google.com/apis/library/calendar-json.googleapis.com
# 3. Share target calendar with the service account email (Make changes to events)
# 4. Download JSON key and set the path below
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=

# ── Notification Channels ─────────────────────────────────────────
# Telegram Bot (free, via @BotFather)
# 1. Create bot: https://t.me/BotFather → /newbot → get token
# 2. Create channel: https://t.me → New Channel → add bot as admin
# 3. Set TELEGRAM_BOT_TOKEN and TELEGRAM_CHANNEL_ID below
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ── Calendar ──────────────────────────────────────────────────────
# JWT token for CrewAI to write calendar events (obtain via POST /api/auth/login)
CALENDAR_API_KEY=
# Default calendar series ID for crew operations (set after creating a series)
CALENDAR_DEFAULT_SERIES=